{
  "name": "mascot-plugin",
  "version": "1.0.0",
  "description": "a plugin to add my mascot to any website/software with GUI",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup --entry.index packages/core/src/index.ts --entry.react packages/react/src/index.ts --entry.webcomponent packages/web-component/src/index.ts --entry.auto packages/auto-init/src/index.ts --entry.terminal packages/renderers/terminal/src/index.ts --entry.node packages/runtimes/node/src/index.ts --entry.cli packages/cli/src/index.ts --entry.electron packages/runtimes/electron/src/index.ts --entry.tauri packages/runtimes/tauri/src/index.ts --entry.vue packages/vue/src/index.ts --entry.svelte packages/svelte/src/index.ts --entry.solid packages/solid/src/index.ts --entry.preact packages/preact/src/index.ts --entry.plugins packages/plugins/src/index.ts --entry.obs packages/integrations/obs/src/index.ts --entry.asset-pipeline packages/asset-pipeline/src/index.ts --entry.packer packages/packer/src/index.ts --entry.packbin packages/packer/src/bin.ts --entry.manager packages/manager/src/index.ts --entry.unity packages/integrations/unity/src/index.ts --entry.reactnative packages/runtimes/react-native/src/index.ts --external pngjs --external omggif --external react-native --external @shopify/react-native-skia --dts --format esm,cjs --clean --out-dir dist",
    "lint": "eslint .",
    "test": "vitest run",
    "example": "esbuild packages/auto-init/src/index.ts --bundle --format=iife --global-name=TinyMascot --outfile=example/tiny-mascot.global.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ch1kim0n1/mascot-plugin.git"
  },
  "keywords": [
    "mascot",
    "overlay",
    "sprite",
    "animation",
    "character",
    "pet",
    "canvas",
    "terminal",
    "electron",
    "tauri",
    "react",
    "vue",
    "svelte",
    "solid",
    "preact",
    "web-component",
    "game",
    "engine"
  ],
  "author": "ch1kim0n1",
  "license": "ISC",
  "type": "module",
  "bin": {
    "mascot-pack": "dist/packbin.cjs"
  },
  "sideEffects": [
    "**/*.css",
    "./packages/web-component/src/index.ts"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bugs": {
    "url": "https://github.com/ch1kim0n1/mascot-plugin/issues"
  },
  "homepage": "https://github.com/ch1kim0n1/mascot-plugin#readme",
  "peerDependencies": {
    "@shopify/react-native-skia": "*",
    "@tauri-apps/api": "*",
    "electron": "*",
    "preact": "^10.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-native": "*",
    "solid-js": "^1.0.0",
    "svelte": "^4.0.0",
    "vue": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    },
    "preact": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "electron": {
      "optional": true
    },
    "@tauri-apps/api": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "@shopify/react-native-skia": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^10.4.1",
    "jsdom": "^29.1.1",
    "preact": "^10.0.0",
    "solid-js": "^1.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vue": "^3.0.0"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./web-component": {
      "types": "./dist/webcomponent.d.ts",
      "import": "./dist/webcomponent.js",
      "require": "./dist/webcomponent.cjs"
    },
    "./auto-init": {
      "types": "./dist/auto.d.ts",
      "import": "./dist/auto.js",
      "require": "./dist/auto.cjs"
    },
    "./terminal": {
      "types": "./dist/terminal.d.ts",
      "import": "./dist/terminal.js",
      "require": "./dist/terminal.cjs"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "require": "./dist/node.cjs"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js",
      "require": "./dist/cli.cjs"
    },
    "./electron": {
      "types": "./dist/electron.d.ts",
      "import": "./dist/electron.js",
      "require": "./dist/electron.cjs"
    },
    "./tauri": {
      "types": "./dist/tauri.d.ts",
      "import": "./dist/tauri.js",
      "require": "./dist/tauri.cjs"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js",
      "require": "./dist/vue.cjs"
    },
    "./svelte": {
      "types": "./dist/svelte.d.ts",
      "import": "./dist/svelte.js",
      "require": "./dist/svelte.cjs"
    },
    "./solid": {
      "types": "./dist/solid.d.ts",
      "import": "./dist/solid.js",
      "require": "./dist/solid.cjs"
    },
    "./preact": {
      "types": "./dist/preact.d.ts",
      "import": "./dist/preact.js",
      "require": "./dist/preact.cjs"
    },
    "./plugins": {
      "types": "./dist/plugins.d.ts",
      "import": "./dist/plugins.js",
      "require": "./dist/plugins.cjs"
    },
    "./obs": {
      "types": "./dist/obs.d.ts",
      "import": "./dist/obs.js",
      "require": "./dist/obs.cjs"
    },
    "./asset-pipeline": {
      "types": "./dist/asset-pipeline.d.ts",
      "import": "./dist/asset-pipeline.js",
      "require": "./dist/asset-pipeline.cjs"
    },
    "./packer": {
      "types": "./dist/packer.d.ts",
      "import": "./dist/packer.js",
      "require": "./dist/packer.cjs"
    },
    "./manager": {
      "types": "./dist/manager.d.ts",
      "import": "./dist/manager.js",
      "require": "./dist/manager.cjs"
    },
    "./unity": {
      "types": "./dist/unity.d.ts",
      "import": "./dist/unity.js",
      "require": "./dist/unity.cjs"
    },
    "./react-native": {
      "types": "./dist/reactnative.d.ts",
      "import": "./dist/reactnative.js",
      "require": "./dist/reactnative.cjs"
    }
  },
  "optionalDependencies": {
    "omggif": "^1.0.10",
    "pngjs": "^7.0.0"
  }
}
